'''Iter and Gener'''
#1
def generate_squares(n):
    for i in range(n + 1):
        yield i * i

#2
def generate_even_numbers(n):
    for i in range(n + 1):
        if i % 2 == 0:
            yield i

#3
def divisible_by_3_and_4(n):
    for i in range(n + 1):
        if i % 3 == 0 and i % 4 == 0:
            yield i
#4
def squares(a, b):
    for i in range(a, b + 1):
        yield i * i

#5
def countdown(n):
    while n >= 0:
        yield n
        n -= 1

