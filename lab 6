#1
from pathlib import Path

def list_contents(path="."):
    p = Path(path)
    if not p.exists():
        print("Path does not exist")
        return

    print("\nDirectories:")
    print([d.name for d in p.iterdir() if d.is_dir()])

    print("\nFiles:")
    print([f.name for f in p.iterdir() if f.is_file()])

    print("\nAll items:")
    print([item.name for item in p.iterdir()])

