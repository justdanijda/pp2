from functools import reduce
import operator

def multiply_list(numbers):
    return reduce(operator.mul, numbers, 1)

#2
def count_case(s):
    upper = sum(map(str.isupper, s)) 
    lower = sum(map(str.islower, s)) 
    return {"Uppercase": upper, "Lowercase": lower}

#3
def is_palindrome(s):
    return s == s[::-1]

